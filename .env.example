# Optional API auth token. Leave empty to disable backend auth.
API_SECRET=

# Required for stable encrypted credential storage.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Web port exposed by docker-compose.prod.yml.
FRONTEND_PORT=8080

# GitHub Container Registry image location.
GHCR_OWNER=wosa1402
GHCR_REPO=githubstarsmanager
IMAGE_TAG=latest

# Frontend build-time project/update settings.
# Auto update checks and update banners are disabled by default for forked deployments.
VITE_PROJECT_REPO_URL=https://github.com/wosa1402/GitHubStarsManager
VITE_AUTO_UPDATE_CHECK=false
VITE_UPDATE_BANNER=false
# Optional: set a custom version-info.xml URL when you maintain your own releases.
# VITE_UPDATE_INFO_URL=https://raw.githubusercontent.com/wosa1402/GitHubStarsManager/main/versions/version-info.xml
